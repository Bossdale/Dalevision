rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{uid} {
      // Users read their own doc; admins read any doc. No public read.
      allow read: if isSelf(uid) || isAdmin();

      // Registration: own doc only, with forced safe defaults.
      // A user can NEVER create themselves as approved or as admin.
      allow create: if isSelf(uid)
        && request.resource.data.role == "user"
        && request.resource.data.status == "pending";

      // Self edit: profile fields only. role & status must remain UNCHANGED,
      // which is what prevents self-approval / self-promotion to admin.
      allow update: if isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;

      // Admins may change status/role and delete user docs.
      allow update, delete: if isAdmin();
    }

    // ---- Watch Together rooms ----
    match /rooms/{roomId} {
      function isRoomHost() {
        return isSignedIn()
          && exists(/databases/$(database)/documents/rooms/$(roomId))
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid == request.auth.uid;
      }

      // Any signed-in user can read a room (needed to join by link).
      allow read: if isSignedIn();

      // Creator must set themselves as host.
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid;

      // Only the host may change selection / playback / status, or delete.
      allow update, delete: if isRoomHost();

      // Presence: each user writes only their own member doc.
      match /members/{uid} {
        allow read: if isSignedIn();
        allow write: if isSelf(uid);
      }

      // Chat: any signed-in member may post as themselves; no edits/deletes.
      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid;
      }
    }

    // Everything else is denied by default.
  }
}
