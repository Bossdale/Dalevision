# Copy this file to `.env` and fill in your own values.
# NOTE: all VITE_* vars are bundled into the client and are PUBLICLY visible.
# The TMDB key (read-only) and Firebase config are safe to expose by design.
# Never put a real secret in a VITE_ var.

# --- Firebase (Project settings > General > Your apps > SDK config) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- TMDB (https://www.themoviedb.org/settings/api) — v3 API key ---
VITE_TMDB_API_KEY=

# --- LiveKit (optional — for Watch Together camera/mic chat) ---
# Create a free project at https://cloud.livekit.io to get the wss URL, and
# deploy the token Worker in server/livekit-token-worker (see its README).
# If left blank, Watch Together still works (synced player + chat) but the
# camera/mic panel is disabled.
VITE_LIVEKIT_URL=
VITE_LIVEKIT_TOKEN_ENDPOINT=

# --- EmailJS (optional — for the "account approved" email) ---
# Sign up at https://www.emailjs.com, add an email service + a template, then
# fill these in. Template should use variables: to_email, to_name, app_name,
# login_url. If left blank, approval emails are simply skipped.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_APPROVAL_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
