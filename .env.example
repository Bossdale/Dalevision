# Copy this file to `.env` and fill in your own values.
# NOTE: all VITE_* vars are bundled into the client and are PUBLICLY visible.
# The TMDB key (read-only) and Firebase config are safe to expose by design.
# Never put a real secret in a VITE_ var.

# --- Firebase (Project settings > General > Your apps > SDK config) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- TMDB (https://www.themoviedb.org/settings/api) — v3 API key ---
VITE_TMDB_API_KEY=
